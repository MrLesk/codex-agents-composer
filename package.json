{
  "name": "codex-agents-composer",
  "version": "0.1.0",
  "description": "ElectroBun desktop app for composing Codex agents and skills",
  "type": "module",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build": "vite build",
    "build:app": "vite build && electrobun build",
    "build:release": "vite build && electrobun build --env=stable",
    "build:release:canary": "vite build && electrobun build --env=canary",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.1",
    "clsx": "2.1.1",
    "electrobun": "1.16.0",
    "lucide-react": "0.577.0",
    "motion": "12.37.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.2",
    "react-router": "7.13.1",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  }
}
